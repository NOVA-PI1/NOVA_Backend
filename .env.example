APP_NAME="Nova Backend"
ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=*

# Default "fake" lets the API run without calling an external model.
LLM_PROVIDER=fake
LLM_MODEL=nova-fake
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=800

# Configure only the provider you use. Never commit real keys.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

DATABASE_URL=sqlite:///./nova.db
CHROMA_PERSIST_PATH=./chroma_db
BCL_COLLECTION_NAME=nova_bcl
BCL_RELEVANCE_THRESHOLD=0.8
