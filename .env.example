# .env.example - plantilla de entorno (sin secretos)
# Copia este archivo a `.env` y rellena los valores reales.

# General
APP_NAME="NOVA Backend"
ENVIRONMENT="development"
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# Seguridad / Auth
SECRET_KEY="your-strong-secret-here"
JWT_ALGORITHM="HS256"

# LLM provider (elige uno): openai-compatible | groq | openrouter | together | ollama | fake
LLM_PROVIDER="openai-compatible"
LLM_MODEL="modelo-del-proveedor"
LLM_MAX_TOKENS=900

# OpenAI-compatible
OPENAI_API_KEY=""
LLM_BASE_URL="https://proveedor.example/v1"

# Groq
#GROQ_API_KEY=""

# OpenRouter
#OPENROUTER_API_KEY=""

# Together
#TOGETHER_API_KEY=""

# Ollama local
#OLLAMA_BASE_URL="http://127.0.0.1:11434/v1"

# Persistencia
DATABASE_URL="sqlite:///./nova.db"
CHROMA_PERSIST_PATH="./chroma_db"

# Socket / Websockets
SOCKETIO_NAMESPACE="/"

# Logging
LOG_LEVEL="DEBUG"
APP_NAME="Nova Backend"
ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=*

# Default "fake" lets the API run without calling an external model.
LLM_PROVIDER=fake
LLM_MODEL=nova-fake
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=800

# Configure only the provider you use. Never commit real keys.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

DATABASE_URL=sqlite:///./nova.db
CHROMA_PERSIST_PATH=./chroma_db
BCL_COLLECTION_NAME=nova_bcl
BCL_RELEVANCE_THRESHOLD=0.8
